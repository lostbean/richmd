#!/usr/bin/env node
// theme-swap-check — proves the theme-reskin mechanism (design.md §00
// principle P3 "style is swappable, never hardcoded"; §07 theme/diagram
// runtime) is genuinely live, without any markdown-source change.
//
// richmd's CLI has no "pick a theme" flag (bin/richmd.js: `render`/`validate`
// are the only two subcommands, `--offline` the only render flag) — the
// filter always embeds theme/default.css verbatim via
// richmd-filter.lua's theme_style_html(). So the reskin story cannot be
// demonstrated by any richmd invocation; it has to be demonstrated as a
// SEPARATE, post-render step: render once, then swap the embedded
// richmd-theme <style> block's content for examples/custom-theme.css's
// content, and confirm specific --richmd-* custom-property values (and a
// couple of derived rendering facts) genuinely differ between the two.
//
// Why regex-substitution + custom-property text comparison, not a real
// browser: this repo has no headless-browser dependency anywhere (grep
// test/*.js — every "computed style" proof in this codebase, e.g.
// test/diagram-theme.test.js, stubs `getComputedStyle` with a plain
// `getPropertyValue` map rather than invoking a real CSS/layout engine, and
// linkedom — already a dependency — implements the DOM but not CSSOM/
// getComputedStyle). Since every value this check compares is a literal
// `--richmd-color-*`/`--richmd-font-*` declaration inside a `:root { ... }`
// block (not something requiring cascade resolution across the two
// themes — both files declare :root directly), a direct text extraction of
// each custom property's declared value from the two theme sources is an
// exact, honest stand-in for "what getComputedStyle would return on a real
// page," with no loss of rigor for the specific claim being tested here:
// the two themes assign genuinely different values to the same variable
// names, and swapping the <style> block content changes what a browser
// would compute for .richmd-doc's colors and fonts.
//
// Usage: scripts/theme-swap-check
//   Renders examples/custom-theme-demo.md fresh (default theme embedded),
//   builds an in-memory swapped copy (custom-theme.css's content in place
//   of the embedded theme <style> block), and asserts a named set of
//   --richmd-* custom properties + the .custom-definition extension rule
//   differ between the two. Exits 0 on success, 1 with a clear diff on any
//   mismatch. Never writes the swapped HTML to disk — this is a
//   verification step, not a build artifact (the demo doc's OWN golden
//   hash always reflects the DEFAULT theme, per the work order).

// Deliberately CommonJS (require), not ESM `import`, even though this repo's
// package.json sets "type": "module" — matching the working convention
// already established by this extensionless sibling script,
// scripts/design-render (also a #!/usr/bin/env node file with no
// extension): node's extensionless-file module-type resolution is
// context-sensitive (it does not reliably follow "type": "module" the way
// an explicit .mjs/.js file under bin/ or test/ does), so raw top-level
// `import` here produced silently inconsistent behavior across invocation
// paths in practice. `require` is unambiguous for a shebang'd, extensionless
// CLI script and needs no build step.
const { spawnSync } = require("node:child_process");
const { readFileSync, rmSync } = require("node:fs");
const path = require("node:path");

const repoRoot = path.resolve(__dirname, "..");
const cliPath = path.join(repoRoot, "bin", "richmd.js");
const mdPath = path.join(repoRoot, "examples", "custom-theme-demo.md");
const htmlPath = path.join(repoRoot, "examples", "custom-theme-demo.html");
const customThemePath = path.join(repoRoot, "examples", "custom-theme.css");

function fail(message) {
  console.error(`theme-swap-check: FAILED — ${message}`);
  process.exit(1);
}

// 1. Render fresh — never trust a stale .html already on disk.
const renderResult = spawnSync(process.execPath, [cliPath, "render", mdPath], {
  encoding: "utf8",
  cwd: repoRoot,
});
if (renderResult.status !== 0) {
  fail(
    `rendering ${mdPath} failed:\n${renderResult.stderr || renderResult.stdout}`,
  );
}

const defaultHtml = readFileSync(htmlPath, "utf8");
// Clean up the render artifact immediately — this script never leaves a
// generated .html behind (mirrors example-hash-check's own discipline of
// treating examples/ as source, plus scripts/example-hash-check remaining
// the single owner of the committed golden-hash artifact for this doc).
rmSync(htmlPath, { force: true });

// 2. Extract the richmd theme <style> block specifically (there are two
// <style> blocks in the page: Pandoc's own generic one, and richmd's theme
// one — identify richmd's by the --richmd- marker it alone contains).
function extractThemeStyleBlock(html) {
  const blocks = [...html.matchAll(/<style>([\s\S]*?)<\/style>/g)].map(
    (m) => m[1],
  );
  const themeBlock = blocks.find((b) => b.includes("--richmd-"));
  if (!themeBlock) {
    fail("could not find richmd's theme <style> block in rendered HTML");
  }
  return themeBlock;
}

const defaultThemeCss = extractThemeStyleBlock(defaultHtml);
const customThemeCss = readFileSync(customThemePath, "utf8");

// 3. Build the swapped page: same document, same structure, same
// definition/callout/cards/mermaid markup — only the theme <style> block's
// CONTENT changes. Proves the markdown source and its rendered structure
// are completely untouched by the swap.
const swappedHtml = defaultHtml.replace(defaultThemeCss, "\n" + customThemeCss);
if (swappedHtml === defaultHtml) {
  fail("swap produced no change — the theme <style> block was not replaced");
}

// 4. Extract a named set of --richmd-* custom-property declared values from
// each theme's own :root block (light-mode block — the first :root { ... }
// in each file) and confirm they genuinely differ.
function extractRootVar(css, varName) {
  // Matches the FIRST `:root { ... }` block's own declarations (the
  // light-mode token block, §1 in both theme files) up to its closing
  // brace — tolerant of the extra indentation Pandoc adds when it embeds
  // this same CSS text inside a <style> tag (every line gets a couple of
  // leading spaces added), so this one extractor works unmodified against
  // both the raw theme/*.css source and the indented copy pulled back out
  // of rendered HTML.
  const rootMatch = css.match(/:root\s*\{([\s\S]*?)\n[ \t]*\}/);
  if (!rootMatch) return null;
  const rootBlock = rootMatch[1];
  const varMatch = rootBlock.match(new RegExp(`--${varName}:\\s*([^;]+);`));
  return varMatch ? varMatch[1].trim() : null;
}

const comparisons = [
  ["richmd-accent-500", "primary accent color"],
  ["richmd-color-bg", "page background color"],
  ["richmd-color-text", "body text color"],
  ["richmd-font-heading", "heading display font"],
  ["richmd-font-body", "body font"],
];

const mismatches = [];
const report = [];
for (const [varName, label] of comparisons) {
  const before = extractRootVar(defaultThemeCss, varName);
  const after = extractRootVar(customThemeCss, varName);
  if (before === null || after === null) {
    fail(`could not extract --${varName} from one of the two theme sources`);
  }
  if (before === after) {
    mismatches.push(
      `--${varName} (${label}) did NOT change: both themes declare ${before}`,
    );
  }
  report.push({ varName, label, before, after });
}

if (mismatches.length > 0) {
  fail(
    "expected every compared --richmd-* variable to differ between themes, but some did not:\n  " +
      mismatches.join("\n  "),
  );
}

// 5. Confirm the custom "definition" extension's OWN styling
// (.custom-definition / .custom-definition-term) is present in the custom
// theme and absent from the default theme — proving the extension's CSS
// ships alongside the theme, distinct from richmd's built-in block styling.
if (defaultThemeCss.includes(".custom-definition")) {
  fail(
    "richmd's default theme unexpectedly already defines .custom-definition — " +
      "the extension's styling should be new, only in custom-theme.css",
  );
}
if (!customThemeCss.includes(".custom-definition-term")) {
  fail(
    "custom-theme.css does not define .custom-definition-term — the definition " +
      "extension's own styling is missing from the custom theme",
  );
}
// Confirm it is visually distinct from richmd's built-in callout panel: a
// different left-accent treatment (built-in callouts have no border-left;
// the definition panel's border-left is its distinguishing visual marker).
if (!customThemeCss.match(/\.custom-definition\s*\{[^}]*border-left/)) {
  fail(
    "custom-theme.css's .custom-definition rule is missing its distinguishing " +
      "border-left treatment (would make it visually indistinguishable from a plain panel)",
  );
}

// 6. Confirm the markdown source itself never WIRES UP custom-theme.css
// through any richmd/markdown mechanism — a plain-prose mention in
// backticks (explaining the demo, required content per the work order) is
// fine and expected; a markdown link (`](...custom-theme.css)`) or an HTML
// <link.../> or href= pointing at it would be a real mechanism attempt,
// which richmd has no CLI flag to honor anyway (bin/richmd.js: no
// theme-selection option exists), so authoring one would be misleading.
const mdSource = readFileSync(mdPath, "utf8");
const wiresUpTheme =
  /\]\([^)]*custom-theme\.css[^)]*\)/.test(mdSource) ||
  /<link[^>]*custom-theme\.css/.test(mdSource) ||
  /href\s*=\s*["'][^"']*custom-theme\.css/.test(mdSource);
if (wiresUpTheme) {
  fail(
    "examples/custom-theme-demo.md appears to WIRE UP custom-theme.css via a " +
      "link/href — the work order requires the theme swap to be proven " +
      "WITHOUT any markdown mechanism referencing the alternate theme " +
      "(richmd has no CLI theme-selection flag to honor such a reference " +
      "anyway); a plain-prose mention of the filename is fine, an active " +
      "link/embed is not",
  );
}

console.log("theme-swap-check OK — every compared value genuinely changed:");
for (const { varName, label, before, after } of report) {
  console.log(`  --${varName} (${label}): ${before}  ->  ${after}`);
}
console.log(
  "  .custom-definition extension styling: absent from default theme, present in custom-theme.css, visually distinct (border-left accent)",
);
console.log(
  "  examples/custom-theme-demo.md: confirmed to contain no LINK/EMBED mechanism wiring up custom-theme.css (a plain-prose filename mention is present, as required content, but is not a working reference)",
);
process.exit(0);
