#!/usr/bin/env bash
# example-hash-check — design.md §08 CI "example-doc regression check":
# render examples/data-status-report.md fresh, hash the resulting HTML, and
# diff that hash against the committed golden hash file
# (examples/data-status-report.html.sha256). Output only changes on a
# deliberate markup/theme change, never silently — a mismatch here fails the
# build (exit 1).
#
# Determinism note (read before treating a failure as a false positive):
# filter/blocks/vega-lite.lua's render_fn mints a fresh
# `richmd-vega-<math.random(...)>` container id on every single render — by
# design, this differs run to run even with byte-identical source. Rather
# than seed the RNG or otherwise change vega-lite.lua's shipped render
# behavior (out of scope for example/tooling work — see the chunk report),
# this script normalizes that one varying token out of the rendered HTML
# before hashing: every `richmd-vega-[0-9]+` id is rewritten to the fixed
# placeholder `richmd-vega-STABLE` first. This is the ONLY normalization
# applied; any other diff in the rendered output is a real regression.
#
# Usage: scripts/example-hash-check [--update]
#   (no args)  render, hash, compare against the committed golden hash.
#              exit 0 on match, exit 1 with a clear message on mismatch.
#   --update   render, hash, and OVERWRITE the committed golden hash file —
#              the documented one-command path for a contributor who
#              intentionally changed the example's output (wired to
#              `npm run example:update-hash`; see package.json).
set -euo pipefail

usage() {
  echo "usage: $(basename "$0") [--update]" >&2
}

MODE="check"
if [ "$#" -eq 1 ] && [ "$1" = "--update" ]; then
  MODE="update"
elif [ "$#" -gt 0 ]; then
  usage
  exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"

MD_PATH="$REPO_ROOT/examples/data-status-report.md"
HTML_PATH="$REPO_ROOT/examples/data-status-report.html"
GOLDEN_PATH="$REPO_ROOT/examples/data-status-report.html.sha256"
CLI_PATH="$REPO_ROOT/bin/richmd.js"

if [ ! -f "$MD_PATH" ]; then
  echo "error: example source not found: $MD_PATH" >&2
  exit 2
fi

# Render fresh — never trust a stale HTML file already on disk (render.js
# itself writes no output at all on a validation failure, so a nonzero exit
# here is itself a hard failure, not something to paper over).
if ! node "$CLI_PATH" render "$MD_PATH"; then
  echo "error: rendering $MD_PATH failed (see richmd's own error output above)" >&2
  exit 1
fi

if [ ! -f "$HTML_PATH" ]; then
  echo "error: render reported success but $HTML_PATH does not exist" >&2
  exit 2
fi

# Normalize the one known non-deterministic token (vega-lite.lua's
# math.random container id — see header note) before hashing, so the golden
# hash reflects genuine content/markup drift only, never run-to-run noise.
NORMALIZED="$(sed -E 's/richmd-vega-[0-9]+/richmd-vega-STABLE/g' "$HTML_PATH")"
NEW_HASH="$(printf '%s' "$NORMALIZED" | shasum -a 256 | awk '{print $1}')"

if [ "$MODE" = "update" ]; then
  printf '%s\n' "$NEW_HASH" >"$GOLDEN_PATH"
  echo "example-hash-check: golden hash updated: $NEW_HASH"
  echo "example-hash-check: recorded in $GOLDEN_PATH — commit this file alongside your intentional change"
  exit 0
fi

if [ ! -f "$GOLDEN_PATH" ]; then
  echo "error: no committed golden hash at $GOLDEN_PATH (run with --update once to create it)" >&2
  exit 2
fi

OLD_HASH="$(tr -d '[:space:]' <"$GOLDEN_PATH")"

if [ "$NEW_HASH" != "$OLD_HASH" ]; then
  echo "example-hash-check: FAILED"
  echo "  example output changed — if this is intentional, regenerate and recommit the golden hash:"
  echo "    npm run example:update-hash"
  echo "  committed hash: $OLD_HASH"
  echo "  fresh hash:     $NEW_HASH"
  exit 1
fi

echo "example-hash-check OK: $NEW_HASH matches committed golden hash ($GOLDEN_PATH)"
exit 0
