#!/usr/bin/env bash
# example-hash-check — design.md §08 CI "example-doc regression check":
# render an examples/<name>.md fresh, hash the resulting HTML, and diff that
# hash against the committed golden hash file (examples/<name>.html.sha256).
# Output only changes on a deliberate markup/theme change, never silently —
# a mismatch here fails the build (exit 1).
#
# Generic over which example doc to check — defaults to data-status-report
# (the original example this script was written for) so every existing
# caller (package.json's example:hash-check/example:update-hash, CI's
# "example-doc regression check" step) keeps working unchanged. Pass an
# example name (the file's basename under examples/, no extension) to check
# a different doc, e.g. `scripts/example-hash-check design-doc`.
#
# Determinism note (read before treating a failure as a false positive):
# rendering is deterministic — the SAME source always produces the SAME
# bytes — so the rendered HTML is hashed exactly as richmd emits it, with no
# normalization of any kind. Every diff in the rendered output is therefore a
# real regression; there is no run-to-run noise for a mismatch here to be
# blamed on. This script once normalized filter/blocks/mermaid.lua's and
# filter/blocks/vega-lite.lua's per-render `math.random(...)` container ids
# away before hashing, because back then two renders of one source genuinely
# did differ. Those ids are now per-document ordinals (`richmd-mermaid-1`,
# `richmd-vega-1`, ... — issue #22), which made both the non-determinism and
# the normalization papering over it obsolete: hashing the real bytes is what
# keeps these goldens able to catch a future determinism regression at all,
# which a normalizing pass would silently hide.
#
# Usage: scripts/example-hash-check [--update] [example-name]
#   (no args)        render, hash, compare data-status-report against its
#                    committed golden hash. exit 0 on match, exit 1 with a
#                    clear message on mismatch.
#   [example-name]   check examples/<example-name>.md instead of the
#                    default data-status-report.
#   --update         render, hash, and OVERWRITE the committed golden hash
#                    file — the documented one-command path for a
#                    contributor who intentionally changed the example's
#                    output (wired to `npm run example:update-hash` /
#                    `npm run example:design-doc:update-hash`; see
#                    package.json).
#
# Where it renders (and why not in examples/): this script renders a COPY of
# the whole examples/ tree in a throwaway temp directory and hashes the HTML
# produced THERE, so it never writes to — or otherwise touches — the real,
# committed examples/<name>.html at all. A check must not mutate the
# artifact it checks: richmd's `render` subcommand writes its output as a
# sibling .html next to the source .md, and those examples/*.html files are
# COMMITTED, TRACKED artifacts, not build debris. An earlier version of this
# script rendered in place, silently overwriting the tracked file on every
# run; a subsequent `nix fmt` would then reflow the regenerated file, leaving
# the working tree dirty with whitespace-only diffs to committed generated
# files — in direct tension with `nix flake check`, the repo's own
# formatted-tree gate, and an invitation to either commit the noise or
# "fix" it by moving a golden hash, which would silently destroy the very
# render-clean guarantee this hash pinning exists to provide. Rendering
# elsewhere makes that class of bug structurally impossible: there is
# nothing under examples/ for this script to write. (Same reasoning, and the
# same shape, as scripts/theme-swap-check — see its header.) Note that
# `richmd render --check` does not serve here: it byte-compares a fresh
# render against the committed sibling .html, which answers "is the committed
# HTML fresh?", whereas this script pins the rendered OUTPUT ITSELF against a
# golden hash — the question "did this example's markup/theme output change
# at all, deliberately or not?", which survives regenerating the .html.
#
# The WHOLE examples/ directory is copied, not just the one .md file: an
# example resolves its custom block kinds from a sibling `.richmd/`
# extension directory relative to the document's OWN location (ADR-0003),
# and examples/custom-theme-demo.md carries a cross-document link to
# data-status-report.md which must resolve at validate time (§00 invariant:
# cross-document links always resolve). Copying one file alone fails the
# render.
set -euo pipefail

usage() {
  echo "usage: $(basename "$0") [--update] [example-name]" >&2
}

MODE="check"
EXAMPLE_NAME="data-status-report"

for arg in "$@"; do
  case "$arg" in
    --update)
      MODE="update"
      ;;
    -*)
      usage
      exit 2
      ;;
    *)
      EXAMPLE_NAME="$arg"
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"

EXAMPLES_DIR="$REPO_ROOT/examples"
MD_PATH="$EXAMPLES_DIR/$EXAMPLE_NAME.md"
GOLDEN_PATH="$EXAMPLES_DIR/$EXAMPLE_NAME.html.sha256"
CLI_PATH="$REPO_ROOT/bin/richmd.js"

if [ ! -f "$MD_PATH" ]; then
  echo "error: example source not found: $MD_PATH" >&2
  exit 2
fi

# Work in a throwaway copy of the whole examples/ tree — never the real one
# (see this file's header for why, and for why the WHOLE directory).
TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/richmd-example-hash-check-XXXXXX")"
# Best-effort cleanup: TMP_DIR lives under the system temp dir, never the
# repo, so failing to remove it leaves inert litter, not a lost source file.
# This trap is tidiness, not correctness — nothing under examples/ is at
# risk either way, precisely because the render happens elsewhere.
trap 'rm -rf "$TMP_DIR"' EXIT

cp -R "$EXAMPLES_DIR/." "$TMP_DIR/"
TMP_MD_PATH="$TMP_DIR/$EXAMPLE_NAME.md"
TMP_HTML_PATH="$TMP_DIR/$EXAMPLE_NAME.html"
# The copied tree carries the committed .html files along with everything
# else; remove this doc's so the render below cannot be mistaken for a stale
# file already on disk — the hash must always come from output produced by
# THIS run.
rm -f "$TMP_HTML_PATH"

# Render fresh — never trust a stale HTML file already on disk (render.js
# itself writes no output at all on a validation failure, so a nonzero exit
# here is itself a hard failure, not something to paper over).
if ! node "$CLI_PATH" render "$TMP_MD_PATH"; then
  echo "error: rendering $MD_PATH failed (see richmd's own error output above)" >&2
  exit 1
fi

if [ ! -f "$TMP_HTML_PATH" ]; then
  echo "error: render reported success but produced no HTML for $MD_PATH" >&2
  exit 2
fi

# Hash the rendered bytes exactly as richmd emitted them — no normalization
# (see the determinism note in this file's header).
NEW_HASH="$(shasum -a 256 <"$TMP_HTML_PATH" | awk '{print $1}')"

if [ "$MODE" = "update" ]; then
  printf '%s\n' "$NEW_HASH" >"$GOLDEN_PATH"
  echo "example-hash-check: golden hash updated: $NEW_HASH"
  echo "example-hash-check: recorded in $GOLDEN_PATH — commit this file alongside your intentional change"
  exit 0
fi

if [ ! -f "$GOLDEN_PATH" ]; then
  echo "error: no committed golden hash at $GOLDEN_PATH (run with --update once to create it)" >&2
  exit 2
fi

OLD_HASH="$(tr -d '[:space:]' <"$GOLDEN_PATH")"

if [ "$NEW_HASH" != "$OLD_HASH" ]; then
  echo "example-hash-check: FAILED"
  echo "  example output changed — if this is intentional, regenerate and recommit the golden hash:"
  echo "    npm run example:update-hash"
  echo "  committed hash: $OLD_HASH"
  echo "  fresh hash:     $NEW_HASH"
  exit 1
fi

echo "example-hash-check OK: $NEW_HASH matches committed golden hash ($GOLDEN_PATH)"
exit 0
